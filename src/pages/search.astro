---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts"))
  .sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate))
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    deck: post.data.deck,
    category: post.data.category,
    publishDate: post.data.publishDate,
    tags: post.data.tags,
  }));
---

<BaseLayout title="Search - The National Signal" noIndex={true}>
  <section class="searchPage publicationPage">
    <div class="signalPills"><span>Archive</span><span>Search</span></div>
    <h1>Search the signals</h1>
    <p id="searchSummary" class="pageDeck">Enter a topic, category, or phrase in the search bar.</p>
    <div id="searchResults" class="storyList searchResults" aria-live="polite"></div>
  </section>

  <script type="application/json" id="searchIndex" set:html={JSON.stringify(posts)} />
  <script>
    const indexNode = document.getElementById("searchIndex");
    const resultsNode = document.getElementById("searchResults");
    const summaryNode = document.getElementById("searchSummary");
    const query = new URLSearchParams(window.location.search).get("q")?.trim() || "";
    const posts = JSON.parse(indexNode?.textContent || "[]");
    const normalized = query.toLowerCase();
    const hits = normalized ? posts.filter((post) => [post.title, post.deck, post.category, ...post.tags].join(" ").toLowerCase().includes(normalized)) : [];

    if (summaryNode) summaryNode.textContent = query ? `${hits.length} result${hits.length === 1 ? "" : "s"} for "${query}"` : "Enter a topic, category, or phrase in the search bar.";
    if (resultsNode && query) {
      resultsNode.innerHTML = hits.length ? hits.map((post) => `
        <a class="storyCard" href="/p/${post.slug}">
          <div class="storyCardText">
            <div class="meta"><span class="badge">${post.category}</span><span>${post.publishDate}</span></div>
            <h3>${post.title}</h3><p>${post.deck}</p>
          </div>
        </a>`).join("") : `<p class="emptyState">No matching signals yet. Try a broader term.</p>`;
    }
  </script>
</BaseLayout>
