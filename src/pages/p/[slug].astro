---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categoryBanner } from "../../lib/covers";
import { sortPostsNewest } from "../../lib/posts";
import { categoryLabel } from "../../lib/categories";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { id: post.id },
  }));
}

const { id } = Astro.props;
const posts = await getCollection("posts");
const post = posts.find((entry) => entry.id === id);

if (!post) return Astro.redirect("/");

const { Content } = await post.render();
const others = sortPostsNewest(posts.filter((entry) => entry.id !== post.id))
  .slice(0, 3);

const explicitCover = String(post.data.cover || "").trim();
const candidates = [
  explicitCover,
  `/posts/${post.slug}.webp`,
  `/posts/${post.slug}.png`,
  `/posts/${post.slug}.jpg`,
  categoryBanner(post.data.category),
  "/covers/default.webp",
].filter((value, index, all) => value && all.indexOf(value) === index);

const heroImage = candidates[0];
const site = Astro.site ?? new URL("https://thenationalangle.com");
const url = new URL(`/p/${post.slug}`, site).toString();
const words = post.body.trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(words / 220));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.deck,
  datePublished: post.data.publishDate,
  ...(post.data.updatedDate ? { dateModified: post.data.updatedDate } : {}),
  author: { "@type": "Organization", name: post.data.author },
  mainEntityOfPage: url,
  image: new URL(heroImage, site).toString(),
  publisher: { "@type": "Organization", name: "The National Angle" },
};
---

<BaseLayout
  title={`${post.data.title} - The National Angle`}
  description={post.data.deck}
  ogImage={heroImage}
  canonical={url}
>
  <article class="article publicationArticle">
    <div class="signalPills">
      <a class="pill" href={`/c/${post.data.category.toLowerCase()}`}>{categoryLabel(post.data.category)}</a>
      {post.data.tags.slice(0, 3).map((tag) => <span class="pill">{tag}</span>)}
    </div>

    <h1>{post.data.title}</h1>
    <p class="pageDeck">{post.data.deck}</p>

    <div class="heroImage">
      <img id="postHero" src={heroImage} data-srcs={JSON.stringify(candidates)} alt={`Lead image for ${post.data.title}`} loading="eager" />
    </div>

    <div class="meta articleMeta">
      <span>{post.data.author}</span><span class="dot">&bull;</span>
      <time datetime={post.data.publishDate}>{post.data.publishDate}</time><span class="dot">&bull;</span>
      <span>{readingMinutes} min read</span>
    </div>

    <div class="articleActions">
      <button class="shareButton" id="shareArticle" type="button">Share article</button>
      <span id="shareStatus" class="shareStatus" aria-live="polite"></span>
    </div>

    <div class="prose"><Content /></div>

    {post.data.sources.length > 0 && (
      <section class="sources" aria-labelledby="sources-heading">
        <h2 id="sources-heading">Sources and evidence</h2>
        <ol>{post.data.sources.map((source) => <li><a href={source.url} rel="noopener noreferrer">{source.title}</a></li>)}</ol>
      </section>
    )}

    <section class="readnext">
      <h2>Read next</h2>
      {others.map((entry) => (
        <a class="storyCard relatedCard" href={`/p/${entry.slug}`}>
          <div class="storyCardText">
            <div class="meta"><span class="badge">{categoryLabel(entry.data.category)}</span><span>{entry.data.publishDate}</span></div>
            <h3>{entry.data.title}</h3><p>{entry.data.deck}</p>
          </div>
        </a>
      ))}
    </section>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script>
    const image = document.getElementById("postHero");
    if (image instanceof HTMLImageElement) {
      const sources = JSON.parse(image.dataset.srcs || "[]");
      let index = 0;
      image.addEventListener("error", () => {
        index += 1;
        if (index < sources.length) image.src = sources[index];
      });
    }

    const shareButton = document.getElementById("shareArticle");
    const shareStatus = document.getElementById("shareStatus");
    shareButton?.addEventListener("click", async () => {
      try {
        if (navigator.share) {
          await navigator.share({ title: document.title, url: window.location.href });
        } else {
          await navigator.clipboard.writeText(window.location.href);
          if (shareStatus) shareStatus.textContent = "Link copied";
        }
      } catch (error) {
        if (error instanceof Error && error.name !== "AbortError" && shareStatus) {
          shareStatus.textContent = "Copy the address from your browser";
        }
      }
    });
  </script>
</BaseLayout>
