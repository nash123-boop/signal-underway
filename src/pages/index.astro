---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { coverFor } from "../lib/covers";

const posts = (await getCollection("posts")).sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate));
const hero = posts[0];
const latest = posts.slice(1, 9);
---

<BaseLayout title="The National Angle" currentNav="Latest">
  <div class="publicationPage homePage">
    {hero && (
      <section class="leadStory">
        <div class="leadStoryText">
          <div class="signalPills"><span>{hero.data.category}</span>{hero.data.tags.slice(0, 2).map((tag) => <span>{tag}</span>)}</div>
          <h1>{hero.data.title}</h1>
          <p class="pageDeck">{hero.data.deck}</p>
          <div class="pageActions"><a class="btn primary" href={`/p/${hero.slug}`}>Read the article</a><a class="btn" href="/latest">Browse latest</a></div>
        </div>
        <a class="leadStoryMedia" href={`/p/${hero.slug}`} aria-label={`Read ${hero.data.title}`}>
          <img src={coverFor(hero)} alt="" loading="eager" onerror="this.onerror=null;this.src='/covers/default.webp';" />
        </a>
      </section>
    )}

    <section class="storyFeed">
      <h2 class="sectionLabel">Latest</h2>
      <div class="storyList">
        {latest.map((post) => (
          <a class="storyCard" href={`/p/${post.slug}`}>
            <div class="storyCardText">
              <div class="meta"><span class="badge">{post.data.category}</span><span class="dot">&bull;</span><time datetime={post.data.publishDate}>{post.data.publishDate}</time></div>
              <h3>{post.data.title}</h3><p>{post.data.deck}</p>
            </div>
            <div class="storyThumb"><img src={coverFor(post)} alt="" loading="lazy" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
