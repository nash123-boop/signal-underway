---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories } from "../../lib/categories";
import { categoryBanner, coverFor } from "../../lib/covers";

export async function getStaticPaths() {
  return categories.map((category) => ({ params: { category: category.toLowerCase() } }));
}

const cat = (Astro.params.category ?? "").toLowerCase();
const canonicalCat = categories.find((category) => category.toLowerCase() === cat);
if (!canonicalCat) return Astro.redirect("/latest");
const posts = (await getCollection("posts")).filter((post) => post.data.category.toLowerCase() === cat).sort((a, b) => b.data.publishDate.localeCompare(a.data.publishDate));
---

<BaseLayout title={`${canonicalCat} - The National Angle`} currentNav={canonicalCat}>
  <div class="publicationPage">
    <header class="archiveHero">
      <div><div class="signalPills"><span>{canonicalCat}</span><span>Archive</span></div><h1>{canonicalCat}</h1><p class="pageDeck">Reporting and analysis focused on consequential changes in {canonicalCat.toLowerCase()}.</p></div>
      <div class="archiveMedia"><img src={categoryBanner(canonicalCat)} alt="" loading="eager" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
    </header>
    {posts.length === 0 ? <p class="emptyState">No published stories in this category yet.</p> : (
      <section class="storyList archiveList">
        {posts.map((post) => (
          <a class="storyCard" href={`/p/${post.slug}`}>
            <div class="storyCardText"><div class="meta"><span class="badge">{post.data.category}</span><span class="dot">&bull;</span><time datetime={post.data.publishDate}>{post.data.publishDate}</time></div><h3>{post.data.title}</h3><p>{post.data.deck}</p></div>
            <div class="storyThumb"><img src={coverFor(post)} alt="" loading="lazy" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
          </a>
        ))}
      </section>
    )}
  </div>
</BaseLayout>
