---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categories, categoryLabel } from "../../lib/categories";
import { coverFor } from "../../lib/covers";
import { belongsToSection, selectLeadPost, sortPostsNewest } from "../../lib/posts";

export async function getStaticPaths() {
  return categories.map((category) => ({ params: { category: category.toLowerCase() } }));
}

const cat = (Astro.params.category ?? "").toLowerCase();
const canonicalCat = categories.find((category) => category.toLowerCase() === cat);
if (!canonicalCat) return Astro.redirect("/");
const posts = sortPostsNewest((await getCollection("posts")).filter((post) => belongsToSection(post, canonicalCat)));
const lead = selectLeadPost(posts);
const remaining = lead ? posts.filter((post) => post.id !== lead.id) : [];
const secondary = remaining[0];
const headlineRail = remaining.slice(1, 3);
const moreStories = remaining.slice(3);
const sectionTopics: Record<string, string[]> = {
  World: ["Europe", "Middle East", "Asia", "Americas", "Africa"],
  Politics: ["Foreign Policy", "Government", "Elections", "Security"],
  Business: ["Markets", "Companies", "Economy", "Money"],
  Technology: ["Artificial Intelligence", "Energy", "Science", "Infrastructure"],
  Culture: ["Ideas", "Media", "Sport", "History"],
};
const topics = sectionTopics[canonicalCat] ?? [];
const displayCategory = categoryLabel(canonicalCat);
const readingMinutes = (body: string) => Math.max(1, Math.ceil(body.trim().split(/\s+/).filter(Boolean).length / 220));
---

<BaseLayout title={`${displayCategory} - The National Angle`} currentNav={canonicalCat}>
  <div class="publicationPage sectionPage">
    <header class="sectionMasthead">
      <h1>{displayCategory}</h1>
      <nav aria-label={`${displayCategory} topics`}>
        {topics.map((topic) => <a href={`/search?q=${encodeURIComponent(topic)}`}>{topic}</a>)}
      </nav>
    </header>

    {!lead ? <p class="emptyState">No published stories in this section yet.</p> : (
      <>
        <section class={`sectionNewsGrid ${!secondary ? "singleStory" : headlineRail.length === 0 ? "twoStory" : ""}`} aria-label={`Top ${displayCategory} stories`}>
          <article class="sectionPrimaryStory">
            <a class="sectionPrimaryMedia" href={`/p/${lead.slug}`} aria-label={`Read ${lead.data.title}`}>
              <img src={coverFor(lead)} alt="" loading="eager" onerror="this.onerror=null;this.src='/covers/default.webp';" />
            </a>
            <div class="storyLabel">{lead.data.featured ? "Top story" : "Latest"}</div>
            <h2><a href={`/p/${lead.slug}`}>{lead.data.title}</a></h2>
            <p>{lead.data.deck}</p>
            <div class="storyTime">{readingMinutes(lead.body)} min read</div>
          </article>

          {secondary && (
            <article class="sectionSecondaryStory">
              <a class="sectionSecondaryMedia" href={`/p/${secondary.slug}`} aria-label={`Read ${secondary.data.title}`}>
                <img src={coverFor(secondary)} alt="" loading="eager" onerror="this.onerror=null;this.src='/covers/default.webp';" />
              </a>
              <div class="storyLabel">{categoryLabel(secondary.data.category)}</div>
              <h2><a href={`/p/${secondary.slug}`}>{secondary.data.title}</a></h2>
              <p>{secondary.data.deck}</p>
              <div class="storyTime">{readingMinutes(secondary.body)} min read</div>
            </article>
          )}

          {headlineRail.length > 0 && (
            <div class="sectionHeadlineRail">
              {headlineRail.map((post) => (
                <a class="sectionRailStory" href={`/p/${post.slug}`}>
                  <div class="storyLabel">{categoryLabel(post.data.category)}</div>
                  <h2>{post.data.title}</h2>
                  <p>{post.data.deck}</p>
                  <div class="storyTime">{readingMinutes(post.body)} min read</div>
                </a>
              ))}
            </div>
          )}
        </section>

        {moreStories.length > 0 && (
          <section class="storyFeed">
            <div class="sectionHeading"><h2>More in {displayCategory}</h2></div>
            <div class="storyList archiveList">
              {moreStories.map((post) => (
                <a class="storyCard" href={`/p/${post.slug}`}>
                  <div class="storyCardText"><div class="meta"><span class="storyLabel">{categoryLabel(post.data.category)}</span><span class="dot">&bull;</span><span>{readingMinutes(post.body)} min read</span></div><h3>{post.data.title}</h3><p>{post.data.deck}</p></div>
                  <div class="storyThumb"><img src={coverFor(post)} alt="" loading="lazy" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </div>
</BaseLayout>
