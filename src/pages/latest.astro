---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { categoryBanner, coverFor } from "../lib/covers";
import { sortPostsNewest } from "../lib/posts";

const posts = sortPostsNewest(await getCollection("posts"));
---

<BaseLayout title="Latest - The National Angle">
  <div class="publicationPage">
    <header class="archiveHero">
      <div><div class="signalPills"><span>Latest</span><span>All categories</span></div><h1>Latest</h1><p class="pageDeck">The newest reporting and analysis from The National Angle.</p></div>
      <div class="archiveMedia"><img src={categoryBanner("latest")} alt="" loading="eager" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
    </header>
    <section class="storyList archiveList">
      {posts.map((post) => (
        <a class="storyCard" href={`/p/${post.slug}`}>
          <div class="storyCardText"><div class="meta"><span class="badge">{post.data.category}</span><span class="dot">&bull;</span><time datetime={post.data.publishDate}>{post.data.publishDate}</time></div><h3>{post.data.title}</h3><p>{post.data.deck}</p></div>
          <div class="storyThumb"><img src={coverFor(post)} alt="" loading="lazy" onerror="this.onerror=null;this.src='/covers/default.webp';" /></div>
        </a>
      ))}
    </section>
  </div>
</BaseLayout>
